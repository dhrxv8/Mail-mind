# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
FRONTEND_URL=https://<your-frontend-domain>

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>

# ── Redis / arq ───────────────────────────────────────────────────────────────
REDIS_URL=redis://default:<password>@<host>:6379

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
SECRET_KEY=<generate-with-backend/scripts/generate_keys.py>

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_REDIRECT_URI=https://<your-backend-domain>/auth/google/callback

# ── Google Pub/Sub (real-time Gmail sync) ─────────────────────────────────────
PUBSUB_TOPIC=projects/<your-gcp-project>/topics/gmail-notifications
PUBSUB_VERIFICATION_TOKEN=<your-webhook-shared-secret>
GOOGLE_APPLICATION_CREDENTIALS=/app/service-account.json

# ── Encryption (AES-256 for stored OAuth tokens) ─────────────────────────────
ENCRYPTION_KEY=<generate-with-backend/scripts/generate_keys.py>

# ── Error tracking (optional) ─────────────────────────────────────────────────
SENTRY_DSN=<your-sentry-dsn>

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=<your-razorpay-key-id>
RAZORPAY_KEY_SECRET=<your-razorpay-key-secret>
RAZORPAY_PLAN_ID_INR=<your-inr-plan-id>
RAZORPAY_PLAN_ID_USD=<your-usd-plan-id>
RAZORPAY_WEBHOOK_SECRET=<your-razorpay-webhook-secret>
